function oneInputArg.metadata {
  public: true,
  inputArgs: [ 
    {
      name: value,
      type: i16,
      allocatedOn: stack,
      immutable: false
    }
  ],
  outputArgs: [ 
    {
      name: status,
      type: bool,
      allocatedOn: stack,
      immutable: false
    },
    {
      name: message,
      type: string,
      allocatedOn: stack,
      immutable: false
    }
  ]
}.body {
  data myInteger.metadata {
    type: i8,                      // if you forget to set -> compiler error!
    memorySize: sizeof(i8),      // should be set by compiler and you can't change it -> otherwise compiler error!
    allocationOn: stack,
    compTime.immutable: true,
    compTime.initValue: 12,
    runtime.immutable: true,
    runtime.initValue:           // no need to set it, compiler will set it since it's a compTime.immutable.
  }
  print("myInteger: {}\n", myInteger);

  data myMutableInteger.metadata {
    type: i32,                      // if you forget to set -> compiler error!
    memorySize: sizeof(i32),      // should be set by compiler and you can't change it -> otherwise compiler error!
    allocationOn: stack,
    compTime.immutable: false,
    compTime.initValue: 0,
    runtime.immutable: false,
    runtime.initValue: 989
  }
  println("myMutable Integer: {}, value: {}", myMutableInteger, value);

  status: true;
  message : "passed!";
}
