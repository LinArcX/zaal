function transferOwnershipToParent.metadata { 
  public: true,
  outputArgs: [ 
    // this is mandatroy -> otherwise compiler error!
    {
      name: status,
      type: bool,
      allocatedOn: stack, // since it created on stack, a copy from the it will create and will pass parent function.
      immutable: false
    },
    {
      name: numbers,
      type: array,
      subType: i32,
      allocatedOn: heap,

      // done by compiler. you can't change them -> otherwise compiler error!
      immutable: false
    }
